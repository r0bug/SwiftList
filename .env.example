# ─── Database ──────────────────────────────────────────────
# Standalone install: a database named "swiftlist" with the "swiftlist" schema.
# install.sh creates these for you, or `docker compose up -d postgres` will too.
# To use a cloud Postgres (Neon, RDS, Cloud SQL), only this URL needs to change.
DATABASE_URL="postgresql://swiftlist:swiftlist@localhost:5432/swiftlist?schema=swiftlist&connection_limit=10&pool_timeout=30"

# ─── Server ───────────────────────────────────────────────
PORT=3004
JWT_SECRET="CHANGE_ME_run_openssl_rand_-hex_32"
# For local installs PUBLIC_IMAGE_BASE_URL points at the loopback. For remote
# installs, set it to a hostname your Chrome extension can reach (and that
# resolves to image URLs your DB has stored).
PUBLIC_IMAGE_BASE_URL="http://localhost:3004"
PUBLIC_IMAGES_DIR="public-images"
UPLOADS_DIR="uploads"

# ─── Vision LLM ───────────────────────────────────────────
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-5"
AI_BATCH_SIZE=20

# ─── Watcher ──────────────────────────────────────────────
SWIFTLIST_API_BASE="http://localhost:3004"
SWIFTLIST_API_KEY=""
# Folder the watcher daemon ingests from. install.sh uses ~/swiftlist-inbox
# if left blank.
SWIFTLIST_WATCH_FOLDER=""
WITH_TRAY=0

# ─── Optional eBay Browse API (read-only sold lookups) ────
EBAY_BROWSE_CLIENT_ID=""
EBAY_BROWSE_CLIENT_SECRET=""

# ─── Optional CDN mirror (Photo.cdnUrl) ───────────────────
IMAGE_MIRROR=""        # "" | "s3"
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ─── Optional comptool mirror ─────────────────────────────
COMPTOOL_MIRROR_BASE=""
COMPTOOL_MIRROR_API_KEY=""
