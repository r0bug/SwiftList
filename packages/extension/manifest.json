{
  "manifest_version": 3,
  "name": "swiftlist",
  "version": "0.2.0",
  "description": "Drive eBay's listing UI from your swiftlist database. Find sold comps, populate drafts, resume where you left off.",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "alarms"],
  "host_permissions": [
    "https://www.ebay.com/*",
    "http://localhost:3004/*",
    "https://list.robug.com/*",
    "https://listflow.robug.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.ebay.com/sch/*"],
      "js": ["lib/api.js", "content-sold.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ebay.com/itm/*"],
      "js": ["lib/api.js", "content-detail.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sl/sell*",
        "https://www.ebay.com/lstng*"
      ],
      "js": ["lib/api.js", "content-listing.js", "content-draft.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ebay.com/sh/lst/drafts*"],
      "js": ["lib/api.js", "content-drafts-list.js"],
      "run_at": "document_idle"
    }
  ]
}
